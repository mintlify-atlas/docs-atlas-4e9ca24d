  "keyFeatures": [
    "Authentication & session management with multiple login methods (email/password, OTP, social login)",
    "Document CRUD operations with local caching and real-time updates",
    "Meta data and permission management for Frappe doctypes",
    "File upload and storage handling with progress tracking",
    "Translation and internationalization support",
    "Real-time communication via Socket.IO",
    "Dashboard and UI component management",
    "Advanced filtering and querying capabilities",
    "Tag-based document organization",
    "Document assignment and workflow management"
  ],
  "publicApiSurface": [
    "Renovation.init()",
    "AuthController.login()",
    "AuthController.logout()",
    "AuthController.sendOTP()",
    "AuthController.verifyOTP()",
    "ModelController.getDoc()",
    "ModelController.getList()",
    "ModelController.saveDoc()",
    "ModelController.deleteDoc()",
    "ModelController.newDoc()",
    "ModelController.assignDoc()",
    "ModelController.addTag()",
    "MetaController.getDocMeta()",
    "PermissionController.hasPerm()",
    "PermissionController.getDocPerm()",
    "StorageController.uploadFile()",
    "TranslationController.loadTranslations()",
    "TranslationController.getMessage()",
    "DashboardController.getDashboardMeta()",
    "DashboardController.getDashboardData()",
    "RenovationDocument",
    "DBFilter",
    "RequestResponse"
  ]
